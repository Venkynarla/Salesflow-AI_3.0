# NVIDIA/OpenAI-compatible API
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

# Database
# Local default uses SQLite (fine for local dev / testing).
# For production on Render, use your Supabase connection-pooling URI instead, e.g.:
# DATABASE_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres
DATABASE_URL=sqlite:///./sales_automation.db

# SMTP / Gmail
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SENDER_NAME=Venkat

# Optional: keep dev mode true if you don't want real emails sent
EMAIL_DEV_MODE=true
